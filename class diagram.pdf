package com.cinema.api;

import java.util.List;
import com.cinema.model.Movie;
import com.cinema.service.CinemaService;
import jakarta.ws.rs.GET;
import jakarta.ws.rs.PUT;
import jakarta.ws.rs.Path;
import jakarta.ws.rs.PathParam;
import jakarta.ws.rs.Consumes;
import jakarta.ws.rs.Produces;
import jakarta.ws.rs.core.MediaType;
import jakarta.ws.rs.core.Response;

@Path("/movie")
@Produces(MediaType.APPLICATION_JSON)
public class MovieResource {

    private final CinemaService service = new CinemaService();

    // ✅ GET API 1 – retrieve all movies
    @GET
    public Response getAllMovies() {
        List<Movie> movies = service.getAllMovies();
        return Response.ok(movies).build();
    }

    // ✅ PUT API – update movie by ID
    @PUT
    @Path("/{id}")
    @Consumes(MediaType.APPLICATION_JSON)
    public Response updateMovie(@PathParam("id") int id, Movie updatedMovie) {
        // Check if the movie exists
        Movie existingMovie = service.getMovieById(id);
        
        if (existingMovie == null) {
            return Response.status(Response.Status.NOT_FOUND)
                    .entity("Movie with ID " + id + " not found")
                    .build();
        }
        
        // Set the ID from the path parameter to ensure we update the correct movie
        updatedMovie.setId(id);
        
        // Update the movie
        boolean success = service.updateMovie(updatedMovie);
        
        if (success) {
            return Response.ok(updatedMovie)
                    .entity("Movie updated successfully")
                    .build();
        } else {
            return Response.status(Response.Status.INTERNAL_SERVER_ERROR)
                    .entity("Failed to update movie")
                    .build();
        }
    }
}